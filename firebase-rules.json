{
  "rules": {
    "rpg-quests": {

      "users": {
        "$uid": {
          ".read":  "$uid === auth.uid || root.child('rpg-quests/users/' + auth.uid + '/role').val() === 'admin'",
          ".write": "$uid === auth.uid || root.child('rpg-quests/users/' + auth.uid + '/role').val() === 'admin'"
        }
      },

      "quests": {
        ".read":  "auth !== null",
        ".write": "root.child('rpg-quests/users/' + auth.uid + '/role').val() === 'admin'"
      },

      "userQuests": {
        "$uid": {
          ".read":  "$uid === auth.uid || root.child('rpg-quests/users/' + auth.uid + '/role').val() === 'admin'",
          ".write": "$uid === auth.uid || root.child('rpg-quests/users/' + auth.uid + '/role').val() === 'admin'"
        }
      },

      "submissions": {
        ".read":  "root.child('rpg-quests/users/' + auth.uid + '/role').val() === 'admin'",
        ".write": "auth !== null",
        "$subId": {
          ".read": "data.child('userId').val() === auth.uid || root.child('rpg-quests/users/' + auth.uid + '/role').val() === 'admin'"
        }
      },

      "ranking": {
        ".read":  "auth !== null",
        ".write": "root.child('rpg-quests/users/' + auth.uid + '/role').val() === 'admin'"
      },

      "meta": {
        ".read":  "root.child('rpg-quests/users/' + auth.uid + '/role').val() === 'admin'",
        ".write": "root.child('rpg-quests/users/' + auth.uid + '/role').val() === 'admin'"
      }

    }
  }
}
