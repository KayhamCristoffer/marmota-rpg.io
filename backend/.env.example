PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# MongoDB
MONGO_URI=mongodb://localhost:27017/rpg-quests

# Discord OAuth2
# Crie em: https://discord.com/developers/applications
DISCORD_CLIENT_ID=SEU_CLIENT_ID_AQUI
DISCORD_CLIENT_SECRET=SEU_CLIENT_SECRET_AQUI
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback

# Session Secret (troque por uma string aleatória forte)
SESSION_SECRET=mude-para-uma-chave-secreta-forte-aqui

# Cloudinary (opcional - para upload de imagens na nuvem)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
